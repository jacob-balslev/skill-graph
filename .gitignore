# Transient sweep checkpoint state — regenerated every run. Skills audit
# findings themselves (audits/<skill>/findings.md) are committed per
# `docs/library-audit-workflow.md`; the checkpoint and ledger are not.
audits/_state/
audits/sweep-ledger.jsonl

# Local-only agent harness artifacts (Claude Code state, research notes,
# auxiliary audit outputs). These can carry filesystem paths and session
# telemetry that aren't meant to ship publicly. Maintainers who want to
# commit a specific audit/research artifact should do so explicitly rather
# than by `git add .`.
.claude/
.artifacts/
.research/
.roundtable/
# OpenCode runtime progress/telemetry output — skill-upgrade run records, audit
# progress, A/B apply-output. Runtime artifacts (a "run result", not source), like
# audits/_state/ above. Untracked + scan-excluded so doc-drift does not false-red on
# the `schema_version: 7` strings these run-records legitimately RECORD (the FROM
# value of a v7→v8 upgrade is data, not a stale doc reference). SH-6638 class.
.opencode/

# Personal AI usage tracker — belongs only in the Development root, never in
# this public tooling repo. It carries subscription cost / quota / billing data.
# Ignored here so a `git add .` / commit-all snapshot can't re-introduce it
# (SH-6142). The canonical, auto-generated copy lives at ~/Development/USAGE.md.
USAGE.md

# Node
node_modules/

# macOS
.DS_Store

# Editor state
.vscode/
.idea/
.skill-graph/_routing-eval.manifest.json
.skill-graph/_routing-eval-cli.manifest.json
.skill-graph/_route-cli.manifest.json
skills.manifest.json

# `skill-graph render` default output — compiled consumable skills, regenerated
# on demand. The canonical source is committed; the compiled artifact is not
# (it is a `query result`, not a source row). A consumer renders it themselves.
dist/
