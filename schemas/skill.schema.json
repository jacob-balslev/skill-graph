{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillgraph.dev/schemas/skill.schema.json",
  "title": "Skill Graph Skill Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "description",
    "version",
    "type",
    "family",
    "scope",
    "owner",
    "freshness",
    "drift_check",
    "eval_status"
  ],
  "properties": {
    "schema_version": {
      "oneOf": [
        { "type": "integer", "const": 1 },
        { "type": "string", "pattern": "^[0-9]+$" }
      ]
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-/:]*$"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "type": {
      "type": "string",
      "enum": ["capability", "workflow", "router", "overlay"]
    },
    "family": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": ["operational", "reference", "generic"]
    },
    "owner": {
      "type": "string"
    },
    "freshness": {
      "type": "string",
      "format": "date"
    },
    "drift_check": {
      "type": "string",
      "format": "date"
    },
    "eval_status": {
      "type": "string",
      "enum": ["none", "pending", "evals", "evals+trigger", "passing", "active"]
    },
    "stability": {
      "type": "string",
      "enum": ["experimental", "stable", "frozen", "deprecated"]
    },
    "license": {
      "type": "string"
    },
    "compatibility": {
      "type": "string"
    },
    "allowed-tools": {
      "type": "string"
    },
    "extends": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "route_groups": {
      "type": "array",
      "items": { "type": "string" }
    },
    "relations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adjacent": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boundary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verify_with": {
          "type": "array",
          "items": { "type": "string" }
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "grounding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain_object",
        "grounding_mode",
        "truth_sources",
        "failure_modes",
        "evidence_priority"
      ],
      "properties": {
        "domain_object": { "type": "string" },
        "grounding_mode": {
          "type": "string",
          "enum": ["repo_specific", "universal", "hybrid"]
        },
        "truth_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure_modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_priority": {
          "type": "string",
          "enum": ["repo_code_first", "general_knowledge_first", "equal"]
        }
      }
    },
    "portability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "exports"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "exports": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["agent-skills", "cursor", "windsurf", "copilot", "agents-md"]
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": { "const": "overlay" }
        }
      },
      "then": {
        "required": ["extends"]
      }
    },
    {
      "if": {
        "properties": {
          "scope": { "const": "operational" }
        },
        "required": ["scope"]
      },
      "then": {
        "required": ["grounding"]
      }
    }
  ]
}
