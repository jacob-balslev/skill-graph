{
  "_comment": "JSON-LD @context for Skill Graph v8 frontmatter. Maps authored fields to W3C standard vocabularies so a Skill Graph SKILL.md can be projected into RDF/OWL/SKOS consumers without changing the authoring surface. v8 authored fields (subject, public, taxonomy_domain, scope, project, repo, keywords, relations, grounding.subject_matter, and project-relevance activation fields) are projected through this context.",
  "_version": "3.3.0",
  "_schema_version_target": 8,
  "_references": {
    "skos": "https://www.w3.org/TR/skos-reference/",
    "owl": "https://www.w3.org/TR/owl2-overview/",
    "dcterms": "https://www.dublincore.org/specifications/dublin-core/dcmi-terms/",
    "prov": "https://www.w3.org/TR/prov-o/",
    "spdx": "https://spdx.org/licenses/",
    "schema": "https://schema.org/",
    "fair": "https://www.nature.com/articles/sdata201618"
  },
  "_adr_anchors": {
    "0001": "Initial SKOS-aligned predicate set (related/broader/narrower additions; adjacent deprecation).",
    "0002": "JSON-LD @context coverage policy.",
    "0006": "Historical predicate decision: boundary stayed separate from disjoint_with because sg:disjointOwnership is routing-layer exclusion while disjoint_with is formal OWL class-disjointness. ADR 0018 later renamed the authored field to relations.suppresses while preserving the sg:disjointOwnership predicate.",
    "0011": "Four-verdict Audit Status (structural/truth/comprehension/application) replaces the single audit_verdict; audit_verdict retained for back-read of unmigrated manifests.",
    "0017": "v8 entity-vocabulary completion: top-level `domain` renamed `taxonomy_domain`, `scope` repurposed as free-text PRD content, publishability moved to boolean `public`, `project[]` and `repo[]` added as belonging-entity fields, `workspace_tags` removed (finishing the original ADR-0017 promise), `grounding.domain_object` renamed `grounding.subject_matter`.",
    "0018": "relations.boundary renamed to relations.suppresses and top-level boundary renamed to concept_boundary; both aliases were removed from the canonical schema/context once corpus usage reached zero on 2026-06-13."
  },
  "_term_collisions": {
    "boundary": "The top-level Understanding alias `boundary` and the property-scoped `relations.boundary` alias were retired from the canonical schema on 2026-06-13. Canonical authored skills use `concept_boundary` for concept edges and `relations.suppresses` for routing-layer exclusion."
  },
  "@context": {
    "sg": "https://skillgraph.dev/vocab#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "dcat": "http://www.w3.org/ns/dcat#",
    "spdx": "http://spdx.org/rdf/terms#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "name": "dcterms:identifier",
    "description": "dcterms:description",
    "license": {
      "@id": "dcterms:license",
      "@type": "@id",
      "_note": "SPDX identifier; resolve against spdx:licenseId"
    },
    "stability": "sg:stability",
    "superseded_by": {
      "@id": "prov:wasRevisionOf",
      "@type": "@id",
      "@reverse": false
    },
    "scope": {
      "@id": "sg:scope",
      "_note": "v8: PRD-style free-text scope statement, no enum. The publishability role is carried by the boolean `public`."
    },
    "public": {
      "@id": "sg:public",
      "_note": "v8: Boolean publishability gate. true = safe for public marketplace release; false = carries private data, never published. Replaced the `deployment_target` enum (ADR-0017 amendment) — publishability, not deployment location, is the export gate. Project-grounding moved to `grounding` + `project[]`."
    },
    "project": {
      "@id": "sg:project",
      "@container": "@set",
      "_note": "v8: Projects this skill is linked to. Array of {handle, role} objects. Replaces the original v8 `workspace_tags`."
    },
    "handle": "sg:entityHandle",
    "role": "sg:projectRole",
    "subject": {
      "@id": "sg:subject",
      "_note": "Primary classification — what the skill teaches. Closed 12-value enum (backend-engineering, frontend-engineering, software-architecture, data-engineering, agent-ops, ai-engineering, quality-assurance, design, reasoning-strategy, software-engineering-method, knowledge-organization, product-domain). See docs/adr/0020-twelve-shelf-competency-reaxis.md."
    },
    "subjects": {
      "@id": "sg:subjects",
      "@container": "@list",
      "_note": "Polyhierarchy ordered list — first entry is the primary subject (matches `subject`), second is optional secondary. Max 2 entries to keep polyhierarchy the exception, not the default."
    },
    "keywords": {
      "@id": "dcat:keyword",
      "@container": "@set"
    },
    "triggers": {
      "@id": "sg:trigger",
      "@container": "@set"
    },
    "examples": {
      "@id": "sg:positiveExample",
      "@container": "@set"
    },
    "anti_examples": {
      "@id": "sg:negativeExample",
      "@container": "@set"
    },
    "paths": {
      "@id": "sg:pathGlob",
      "@container": "@set"
    },
    "dependencies": {
      "@id": "schema:softwareRequirements",
      "@container": "@set"
    },
    "codebase_layer": {
      "@id": "sg:codebaseLayer",
      "@container": "@set",
      "_note": "Architectural or system layer this skill applies to. Used as a project-relevance activation signal alongside paths, dependencies, tasks, environments, and internal tools."
    },
    "applicable_tasks": {
      "@id": "sg:applicableTask",
      "@container": "@set",
      "_note": "Concrete task types this skill assists with. Complements free-text scope with deterministic task-intent activation."
    },
    "project_adoption_stage": {
      "@id": "sg:projectAdoptionStage",
      "_note": "Project-local pattern lifecycle: legacy, current-standard, experimental-migration, or deprecated. Distinct from document stability."
    },
    "environment": {
      "@id": "sg:targetEnvironment",
      "@container": "@set",
      "_note": "Project environment or runtime context where this skill applies."
    },
    "internal_tools": {
      "@id": "sg:internalTool",
      "@container": "@set",
      "_note": "Private/team-specific tools whose presence makes the skill relevant. Distinct from public registry dependencies."
    },
    "allowed-tools": "sg:allowedTools",
    "relations": {
      "@id": "sg:relations",
      "@context": {
        "_note": "Property-scoped context (JSON-LD 1.1). Within `relations`, `suppresses` is the routing-layer anti-ownership predicate. Historical `boundary` aliases no longer appear in the canonical @context. See _term_collisions.boundary.",
        "suppresses": {
          "@id": "sg:disjointOwnership",
          "@container": "@set",
          "_note": "Routing-layer asymmetric exclusion edge — directional. Canonical name as of ADR-0018 (renamed from `boundary` so the name matches the mechanic). Maps to sg:disjointOwnership, a Skill-Graph-specific predicate intentionally weaker than OWL class-disjointness — it makes a routing claim, not a formal ontological one. See ADR 0018."
        }
      }
    },
    "related": {
      "@id": "skos:related",
      "@container": "@set",
      "_note": "SKOS associative relation — symmetric, non-hierarchical"
    },
    "broader": {
      "@id": "skos:broader",
      "@container": "@set",
      "_note": "Cross-skill generalisation — target is a more general skill"
    },
    "narrower": {
      "@id": "skos:narrower",
      "@container": "@set",
      "_note": "Cross-skill specialisation — target is a more specific skill"
    },
    "concept_boundary": {
      "@id": "sg:conceptBoundary",
      "_note": "v6+ Understanding field (string) — things commonly confused with the concept but that are NOT it, expressed as a mechanism. Canonical name as of ADR-0018 (renamed from the top-level `boundary` so the token no longer collides with the routing-layer `relations.suppresses` predicate). See _term_collisions.boundary and SKILL_METADATA_PROTOCOL.md § Understanding."
    },
    "disjoint_with": {
      "@id": "owl:disjointWith",
      "@container": "@set",
      "_note": "Formal OWL class-disjointness assertion — symmetric. Use only when authors genuinely want to claim that no entity can simultaneously be an instance of both classes. Distinct from `relations.suppresses`, which is a weaker routing-layer relation. See ADR 0006."
    },
    "verify_with": {
      "@id": "prov:wasInformedBy",
      "@container": "@set",
      "_note": "PROV-O informational influence — verifier skill informed this skill's claims"
    },
    "depends_on": {
      "@id": "dcterms:requires",
      "@container": "@set"
    },
    "grounding": "sg:grounding",
    "subject_matter": "sg:subjectMatter",
    "grounding_mode": "sg:groundingMode",
    "truth_sources": {
      "@id": "dcterms:source",
      "@container": "@set",
      "_note": "DCMI Source — resource from which the skill's claims are derived"
    },
    "failure_modes": {
      "@id": "sg:failureMode",
      "@container": "@set"
    },
    "evidence_priority": "sg:evidencePriority",
    "compatibility": "sg:compatibility",
    "agent_runtimes": {
      "@id": "sg:compatibleRuntime",
      "@container": "@set"
    },
    "node_version": "sg:nodeVersion",
    "notes": "sg:compatibilityNotes",
    "taxonomy_domain": {
      "@id": "skos:broader",
      "_note": "Hierarchical slash-delimited taxonomy path projects to a chain of skos:broader edges in RDF output. Renamed from the original v8 `domain`."
    },
    "mental_model": {
      "@id": "sg:mentalModel",
      "_note": "Concept block — primitives and their relationships; flat-promoted from concept.mental_model in v6"
    },
    "purpose": {
      "@id": "sg:conceptPurpose",
      "_note": "Concept block — problem the concept solves; flat-promoted from concept.purpose in v6"
    },
    "analogy": {
      "@id": "sg:conceptAnalogy",
      "_note": "Concept block — analogy that preserves the core mechanism; flat-promoted from concept.analogy in v6"
    },
    "misconception": {
      "@id": "sg:conceptMisconception",
      "_note": "Concept block — wrong mental model people bring; flat-promoted from concept.misconception in v6"
    }
  }
}
