{
  "_comment": "JSON-LD @context for Skill Graph v7 frontmatter. Maps authored fields to W3C standard vocabularies so a Skill Graph SKILL.md can be projected into RDF/OWL/SKOS consumers without changing the authoring surface.",
  "_version": "3.1.0",
  "_schema_version_target": 7,
  "_references": {
    "skos": "https://www.w3.org/TR/skos-reference/",
    "owl": "https://www.w3.org/TR/owl2-overview/",
    "dcterms": "https://www.dublincore.org/specifications/dublin-core/dcmi-terms/",
    "prov": "https://www.w3.org/TR/prov-o/",
    "spdx": "https://spdx.org/licenses/",
    "schema": "https://schema.org/",
    "fair": "https://www.nature.com/articles/sdata201618"
  },
  "_adr_anchors": {
    "0001": "Initial SKOS-aligned predicate set (related/broader/narrower additions; adjacent deprecation).",
    "0002": "JSON-LD @context coverage policy.",
    "0006": "boundary stays canonical for routing-layer asymmetric handoff (sg:disjointOwnership); disjoint_with is a separate orthogonal relation for formal OWL class-disjointness (owl:disjointWith). Reverts the `boundary -> disjoint_with` rename proposed in ADR 0001 Decision #2.",
    "0011": "Four-verdict Health Block (structural/truth/comprehension/application) replaces the single audit_verdict; audit_verdict retained for back-read of unmigrated v6 manifests."
  },
  "_term_collisions": {
    "boundary": "The token `boundary` has TWO distinct senses: (1) the v6+ Understanding field (a string teaching the concept's edges) and (2) relations.boundary (the routing-layer anti-ownership predicate, an array). JSON-LD term resolution is by key, not by nesting depth, so a single global term cannot serve both. Resolved via a JSON-LD 1.1 property-scoped @context: top-level `boundary` -> sg:conceptBoundary (the Understanding string); `boundary` appearing inside `relations` -> sg:disjointOwnership (the routing predicate). See https://www.w3.org/TR/json-ld11/#scoped-contexts."
  },
  "@context": {
    "sg": "https://skillgraph.dev/vocab#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "dcat": "http://www.w3.org/ns/dcat#",
    "spdx": "http://spdx.org/rdf/terms#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "name": "dcterms:identifier",
    "description": "dcterms:description",
    "version": "dcterms:hasVersion",
    "schema_version": "sg:schemaVersion",
    "owner": "dcterms:creator",
    "license": {
      "@id": "dcterms:license",
      "@type": "@id",
      "_note": "SPDX identifier; resolve against spdx:licenseId"
    },
    "freshness": {
      "@id": "dcterms:modified",
      "@type": "xsd:date"
    },
    "reviewed_at": {
      "@id": "dcterms:modified",
      "@type": "xsd:date"
    },
    "stability": "sg:stability",
    "marketplace_tier": {
      "@id": "sg:marketplaceTier",
      "_note": "NOT a v7 contract field. Retained only for back-read of legacy manifests. The v7 protocol has no marketplace_tier field."
    },
    "superseded_by": {
      "@id": "prov:wasRevisionOf",
      "@type": "@id",
      "@reverse": false
    },
    "type": "sg:archetype",
    "archetype": "sg:archetype",
    "scope": "sg:scope",
    "category": "sg:browseCategory",
    "categories": {
      "@id": "sg:categories",
      "@container": "@list",
      "_note": "Ordered list — first entry is the primary category, remaining entries are secondaries. Same 6-value enum as `category`. v7 optional, v8 required. See SKILL_METADATA_PROTOCOL.md § Classification."
    },
    "primaryCategory": {
      "@id": "sg:primaryCategory",
      "_note": "Workspace alias for `categories[0]`. Title-case workspace values normalize to the lowercase enum on read. See SKILL_METADATA_PROTOCOL.md § Classification."
    },
    "layerPrimary": {
      "@id": "sg:layerPrimary",
      "_note": "Workspace routing facet for the primary architectural or concern layer. Orthogonal to the human browse category."
    },
    "routingRole": {
      "@id": "sg:routingRole",
      "_note": "Workspace routing facet describing how a router should use the skill (primary, router, verifier, gate, etc.). Orthogonal to the skill archetype."
    },
    "secondary_categories": {
      "@id": "sg:secondaryCategories",
      "@container": "@set",
      "_note": "NOT a v7 contract field. Retained only for back-read of legacy manifests. In v7, cross-category membership is expressed via relations.related (max 5), never a secondary_categories field. See SKILL_METADATA_PROTOCOL.md § Classification disambiguation rule 3."
    },
    "keywords": {
      "@id": "dcat:keyword",
      "@container": "@set"
    },
    "triggers": {
      "@id": "sg:trigger",
      "@container": "@set"
    },
    "examples": {
      "@id": "sg:positiveExample",
      "@container": "@set"
    },
    "anti_examples": {
      "@id": "sg:negativeExample",
      "@container": "@set"
    },
    "paths": {
      "@id": "sg:pathGlob",
      "@container": "@set"
    },
    "allowed-tools": "sg:allowedTools",
    "allowed_tools": "sg:allowedTools",
    "relations": {
      "@id": "sg:relations",
      "@context": {
        "_note": "Property-scoped context (JSON-LD 1.1). Within `relations`, the token `boundary` is the routing-layer anti-ownership predicate, NOT the Understanding-field string. See _term_collisions.boundary.",
        "boundary": {
          "@id": "sg:disjointOwnership",
          "@container": "@set",
          "_note": "Routing-layer asymmetric handoff — directional. Canonical name for wrong-skill routing protection. Maps to sg:disjointOwnership, a Skill-Graph-specific predicate intentionally weaker than OWL class-disjointness — it makes a routing claim, not a formal ontological one. See ADR 0006."
        }
      }
    },
    "adjacent": {
      "@id": "skos:related",
      "@container": "@set",
      "_note": "SKOS associative relation — symmetric, non-hierarchical"
    },
    "related": {
      "@id": "skos:related",
      "@container": "@set",
      "_note": "v3.1 preferred alias for `adjacent`; same SKOS mapping"
    },
    "broader": {
      "@id": "skos:broader",
      "@container": "@set",
      "_note": "Cross-skill generalisation — target is a more general skill"
    },
    "narrower": {
      "@id": "skos:narrower",
      "@container": "@set",
      "_note": "Cross-skill specialisation — target is a more specific skill"
    },
    "boundary": {
      "@id": "sg:conceptBoundary",
      "_note": "v6+ Understanding field (string) — things commonly confused with the concept but that are NOT it, expressed as a mechanism. This is the TOP-LEVEL sense of `boundary`. The routing-layer relations.boundary predicate (sg:disjointOwnership) is defined separately via the property-scoped @context on `relations`. See _term_collisions.boundary and SKILL_METADATA_PROTOCOL.md § Understanding."
    },
    "disjoint_with": {
      "@id": "owl:disjointWith",
      "@container": "@set",
      "_note": "Formal OWL class-disjointness assertion — symmetric. Use only when authors genuinely want to claim that no entity can simultaneously be an instance of both classes. Distinct from `boundary` (which is a weaker routing-layer relation). See ADR 0006."
    },
    "verify_with": {
      "@id": "prov:wasInformedBy",
      "@container": "@set",
      "_note": "PROV-O informational influence — verifier skill informed this skill's claims"
    },
    "depends_on": {
      "@id": "dcterms:requires",
      "@container": "@set"
    },
    "extends": {
      "@id": "prov:wasDerivedFrom",
      "@type": "@id",
      "_note": "Overlay specialisation — PROV-O derivation relation"
    },
    "grounding": "sg:grounding",
    "domain_object": "sg:domainObject",
    "subject": "sg:domainObject",
    "grounding_mode": "sg:groundingMode",
    "claim_scope": "sg:groundingMode",
    "truth_sources": {
      "@id": "dcterms:source",
      "@container": "@set",
      "_note": "DCMI Source — resource from which the skill's claims are derived"
    },
    "failure_modes": {
      "@id": "sg:failureMode",
      "@container": "@set"
    },
    "evidence_priority": "sg:evidencePriority",
    "drift_check": "sg:driftCheck",
    "last_verified": {
      "@id": "prov:generatedAtTime",
      "@type": "xsd:date"
    },
    "verified_at": {
      "@id": "prov:generatedAtTime",
      "@type": "xsd:date"
    },
    "truth_source_hashes": {
      "@id": "sg:truthSourceHash",
      "_note": "Map of normalized truth-source key to SHA-256 hex digest. Complements prov:generatedAtTime with content-addressable evidence."
    },
    "concept": "sg:concept",
    "comprehension_state": "sg:comprehensionState",
    "eval_artifacts": "sg:evalArtifacts",
    "eval_state": "sg:evalState",
    "routing_eval": "sg:routingEval",
    "eval": "sg:eval",
    "artifacts": "sg:evalArtifacts",
    "content_state": "sg:evalState",
    "routing_coverage": "sg:routingEval",
    "eval_last_run": "sg:evalLastRun",
    "at": {
      "@id": "prov:generatedAtTime",
      "@type": "xsd:dateTime"
    },
    "status": "sg:evalRunStatus",
    "runner": "sg:evalRunner",
    "model": "sg:evalModel",
    "receipt": "sg:evalReceipt",
    "receipt_hash": "sg:evalReceiptHash",
    "lifecycle": "sg:lifecycle",
    "stale_after_days": {
      "@id": "sg:staleAfterDays",
      "@type": "xsd:integer"
    },
    "review_cadence": "sg:reviewCadence",
    "runtime_telemetry": "sg:runtimeTelemetry",
    "feedback_source": "sg:feedbackSource",
    "last_updated": {
      "@id": "dcterms:modified",
      "@type": "xsd:date"
    },
    "metrics": "sg:telemetryMetrics",
    "sample_size": {
      "@id": "sg:sampleSize",
      "@type": "xsd:integer"
    },
    "success_rate": {
      "@id": "sg:successRate",
      "@type": "xsd:double"
    },
    "compatibility": "sg:compatibility",
    "runtimes": {
      "@id": "sg:compatibleRuntime",
      "@container": "@set"
    },
    "agent_runtimes": {
      "@id": "sg:compatibleRuntime",
      "@container": "@set"
    },
    "node": "sg:nodeVersion",
    "node_version": "sg:nodeVersion",
    "notes": "sg:compatibilityNotes",
    "portability": "sg:portability",
    "readiness": "sg:portabilityReadiness",
    "targets": {
      "@id": "sg:portabilityTarget",
      "@container": "@set"
    },
    "export_targets": {
      "@id": "sg:portabilityTarget",
      "@container": "@set"
    },
    "urn": {
      "@id": "@id",
      "_note": "Globally-unique persistent identifier (urn:skill:<repo>:<name>). Unlocks FAIR Findability. Optional in v3, recommended for v4."
    },
    "domain": {
      "@id": "skos:broader",
      "_note": "Hierarchical slash-delimited domain path projects to a chain of skos:broader edges in RDF output"
    },
    "workspace_tags": {
      "@id": "dcterms:audience",
      "@container": "@set"
    },
    "routing_bundles": {
      "@id": "sg:routingBundle",
      "@container": "@set"
    },
    "last_audited": {
      "@id": "sg:lastAudited",
      "@type": "xsd:date",
      "_note": "Health Block — date the skill last passed the audit loop (v6+)"
    },
    "last_changed": {
      "@id": "sg:lastChanged",
      "@type": "xsd:date",
      "_note": "Health Block — date the skill frontmatter or body was last modified (v6+)"
    },
    "structural_verdict": {
      "@id": "sg:structuralVerdict",
      "_note": "Health Block — form-layer verdict (gates 1-2, 7): PASS | PASS_WITH_FIXES | FAIL | UNVERIFIED (v7+)"
    },
    "truth_verdict": {
      "@id": "sg:truthVerdict",
      "_note": "Health Block — truth-layer verdict (gates 3-6): PASS | DRIFT | BROKEN | UNVERIFIED (v7+)"
    },
    "comprehension_verdict": {
      "@id": "sg:comprehensionVerdict",
      "_note": "Health Block — comprehension grader verdict (gate 8, demoted in v7): PASS | PROVISIONAL | SHALLOW | REDUNDANT | UNVERIFIED | SKIPPED_BASELINE_HIGH | NA"
    },
    "application_verdict": {
      "@id": "sg:applicationVerdict",
      "_note": "Health Block — application grader verdict (gate 9, v7 primary quality signal): APPLICABLE | REDUNDANT | HARMFUL | MIXED | FALSE_POSITIVE | UNVERIFIED | PROVISIONAL. A skill is only behaviorally certified when this is APPLICABLE."
    },
    "audit_verdict": {
      "@id": "sg:auditVerdict",
      "_note": "Health Block — DEPRECATED in v7. Pre-v7 single aggregate verdict (PASS | PASS_WITH_FIXES | PARTIAL | FAIL | UNKNOWN). Kept in the context for back-read of unmigrated v6 manifests. New consumers should read structural_verdict / truth_verdict / comprehension_verdict / application_verdict directly. See docs/adr/0011-split-audit-verdict-into-four-verdicts.md."
    },
    "eval_score": {
      "@id": "sg:evalScore",
      "@type": "xsd:double",
      "_note": "Health Block — latest aggregate eval grade on a 0.0–5.0 scale (v6+). Written by evaluate-skill.js. NOT a 0.0–1.0 pass rate; see SKILL_METADATA_PROTOCOL.md § eval_score and SKILL_AUDIT_LOOP.md."
    },
    "eval_failed_ids": {
      "@id": "sg:evalFailedIds",
      "@container": "@set",
      "_note": "Health Block — list of eval case IDs that failed in the most recent run (v6+)"
    },
    "lint_verdict": {
      "@id": "sg:lintVerdict",
      "_note": "Health Block — PASS | FAIL | UNKNOWN from the most recent deterministic lint run (v6+). PASS means zero lint errors; warnings do not flip the verdict (there is no `warn` value). Rolls up into structural_verdict."
    },
    "drift_status": {
      "@id": "sg:driftStatus",
      "_note": "Health Block — OK | DRIFT | BROKEN | STALE | NO_BASELINE | EXTERNAL_UNHASHED | UNKNOWN, mirroring the skill-graph-drift.js sentinel verdicts (v6+). Rolls up into truth_verdict."
    },
    "mental_model": {
      "@id": "sg:mentalModel",
      "_note": "Concept block — primitives and their relationships; flat-promoted from concept.mental_model in v6"
    },
    "purpose": {
      "@id": "sg:conceptPurpose",
      "_note": "Concept block — problem the concept solves; flat-promoted from concept.purpose in v6"
    },
    "analogy": {
      "@id": "sg:conceptAnalogy",
      "_note": "Concept block — analogy that preserves the core mechanism; flat-promoted from concept.analogy in v6"
    },
    "misconception": {
      "@id": "sg:conceptMisconception",
      "_note": "Concept block — wrong mental model people bring; flat-promoted from concept.misconception in v6"
    }
  }
}
