{
  "name": "@agent-orchestration-tools/skill-graph",
  "version": "0.4.0",
  "description": "Skill Metadata Protocol schemas plus Skill Graph reference tooling and starter skills for Agent Skills libraries.",
  "private": true,
  "type": "commonjs",
  "license": "Apache-2.0",
  "author": "Jacob Balslev <jacob@agent-orchestration.tools>",
  "homepage": "https://github.com/jacob-balslev/skill-graph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacob-balslev/skill-graph.git"
  },
  "bugs": {
    "url": "https://github.com/jacob-balslev/skill-graph/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-orchestration",
    "agent-orchestration-tools",
    "skills",
    "agent-skills",
    "skill-catalog",
    "skill-metadata",
    "schema-validation",
    "knowledge-graph"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "node scripts/skill-lint.js --include-template",
    "contract": "node scripts/check-contract-consistency.js",
    "manifest:validate": "node scripts/generate-manifest.js --validate-only",
    "routing-eval": "node scripts/skill-graph-routing-eval.js --manifest examples/skills.manifest.sample.json --only-asserted",
    "overlap": "node scripts/skill-overlap.js",
    "drift": "node scripts/skill-graph-drift.js",
    "verify": "npm run lint && npm run contract && npm run manifest:validate && npm run routing-eval && npm run overlap"
  },
  "dependencies": {},
  "devDependencies": {},
  "packageManager": "pnpm@9.15.0"
}
