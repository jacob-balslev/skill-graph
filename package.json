{
  "name": "@skill-graph/cli",
  "version": "0.5.0",
  "description": "Skill Metadata Protocol schemas plus Skill Graph reference tooling and starter skills for SKILL.md libraries.",
  "type": "commonjs",
  "license": "Apache-2.0",
  "author": "Jacob Balslev",
  "homepage": "https://github.com/jacob-balslev/skill-graph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacob-balslev/skill-graph.git"
  },
  "bugs": {
    "url": "https://github.com/jacob-balslev/skill-graph/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-orchestration",
    "skills",
    "skill-md",
    "skill-catalog",
    "skill-metadata",
    "schema-validation",
    "knowledge-graph"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "skill-graph": "bin/skill-graph.js"
  },
  "files": [
    "bin/",
    "docs/",
    "examples/",
    "schemas/",
    "scripts/",
    "skills/",
    "README.md",
    "SKILL_AUDIT_CHECKLIST.md",
    "SKILL_AUDIT_LOOP.md",
    "SKILL_GRAPH.md",
    "SKILL_METADATA_PROTOCOL.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "node scripts/skill-lint.js --include-template",
    "protocol:check": "node scripts/check-protocol-consistency.js",
    "docs:links": "node scripts/check-markdown-links.js",
    "manifest:validate": "node scripts/generate-manifest.js --validate-only",
    "routing-eval": "node scripts/skill-graph-routing-eval.js --manifest examples/skills.manifest.sample.json --only-asserted",
    "export:verify-skill-md": "node scripts/verify-skill-md-export.js",
    "marketplace:export": "node scripts/export-marketplace-skills.js",
    "marketplace:verify": "node scripts/export-marketplace-skills.js --check && node scripts/verify-skill-md-export.js --plain marketplace/skills",
    "overlap": "node scripts/skill-overlap.js",
    "drift": "node scripts/skill-graph-drift.js",
    "test:unit": "node scripts/__tests__/test-v3-1-skos-runtime.js && node scripts/__tests__/test-router-paths.js && node scripts/__tests__/test-v3-1-alias-contract.js && node scripts/__tests__/test-export-parser-drift.js && node scripts/__tests__/test-marketplace-export.js && node bin/skill-graph.js --help",
    "verify": "npm run lint && npm run protocol:check && npm run docs:links && npm run manifest:validate && npm run routing-eval && npm run export:verify-skill-md && npm run overlap && npm run test:unit"
  },
  "dependencies": {},
  "devDependencies": {},
  "packageManager": "pnpm@9.15.0"
}
